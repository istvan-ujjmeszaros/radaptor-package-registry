#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROJECT_ROOT=$(git rev-parse --show-toplevel)
RADAPTOR_ROOT=$(cd "$PROJECT_ROOT/../../.." && pwd)
PHP_CS_FIXER_BIN="$RADAPTOR_ROOT/tools/php-cs-fixer"
COMPOSE_FILE="$RADAPTOR_ROOT/docker-compose-dev.yml"
DOCKER_SERVICE="${RADAPTOR_DOCKER_PHP_SERVICE:-php}"
RUN_IN_DOCKER=0

cd "$PROJECT_ROOT"

if [ ! -x "$PHP_CS_FIXER_BIN" ]; then
	echo -e "${RED}PHP-CS-Fixer is not installed (missing tools/php-cs-fixer in the Radaptor root).${NC}"
	exit 1
fi

if command -v docker >/dev/null 2>&1; then
	if docker compose -f "$COMPOSE_FILE" ps "$DOCKER_SERVICE" 2>/dev/null | grep -q "Up"; then
		RUN_IN_DOCKER=1
	fi
fi

mapfile -d '' -t STAGED_FILES < <(git diff --cached --name-only -z --diff-filter=ACM -- '*.php')

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
	exit 0
fi

echo -e "${YELLOW}Running PHP-CS-Fixer for blog plugin...${NC}"

run_fixer() {
	if [ $RUN_IN_DOCKER -eq 1 ]; then
		docker compose -f "$COMPOSE_FILE" exec -T "$DOCKER_SERVICE" bash -lc \
			"cd /app/plugins/dev/blog && /app/tools/php-cs-fixer fix --config=.php-cs-fixer.php --quiet --path-mode=intersection -- \"\$@\"" \
			bash "${STAGED_FILES[@]}"
	else
		"$PHP_CS_FIXER_BIN" fix --config=.php-cs-fixer.php --quiet --path-mode=intersection -- "${STAGED_FILES[@]}"
	fi
}

if ! run_fixer; then
	echo -e "${RED}PHP-CS-Fixer encountered errors. Please fix them and try again.${NC}"
	exit 1
fi

git add -- "${STAGED_FILES[@]}"

echo -e "${GREEN}PHP-CS-Fixer completed successfully!${NC}"
